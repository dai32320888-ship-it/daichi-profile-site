{
  "name": "rakuten-gear-review-blog",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node scripts/build-a8-browser-data.js && node scripts/build-rakuten-widgets-browser.js && node scripts/build-static.js",
    "rakuten:widgets:import": "node scripts/import-rakuten-widgets-inbox.js",
    "dev": "node server.js",
    "auto:article": "node scripts/auto-rakuten-article.js --seed --max=1",
    "auto:article:dry": "node scripts/auto-rakuten-article.js --seed --max=1 --dry-run",
    "enrich:auto": "node scripts/enrich-auto-articles.js",
    "fix:picks": "node scripts/fix-bad-pick-names.js",
    "fix:ratings": "node scripts/fix-stale-ratings.js",
    "health": "node scripts/site-health-check.js",
    "import:a8": "node scripts/import-a8-inbox.js",
    "queue:seed": "node scripts/seed-article-queue.js",
    "queue:gaps": "node scripts/seed-category-gaps.js",
    "batch:articles": "node scripts/batch-generate-articles.js --max=20"
